<!-- Estrutura HTML (Onde os dados vão aparecer) -->
<section id="fortnite-news">
  <h2>Últimas Notícias</h2>
  <div id="news-container">Carregando notícias...</div>
</section>

<section id="fortnite-shop">
  <h2>Loja de Hoje</h2>
  <div id="shop-container">Carregando loja...</div>
</section>

<script>
  // Função para buscar e renderizar as notícias no site
  async function carregarNoticias() {
    try {
      const resposta = await fetch('https://fortnite-api.com');
      const resultado = await respuesta.json();
      const noticias = resultado.data.br.motds; // Captura notícias do Battle Royale
      
      let html = '';
      noticias.forEach(item => {
        html += `
          <div class="news-card">
            <img src="${item.image}" alt="${item.title}" style="width:300px;">
            <h3>${item.title}</h3>
            <p>${item.body}</p>
          </div>
        `;
      });
      document.getElementById('news-container').innerHTML = html;
    } catch (erro) {
      document.getElementById('news-container').innerHTML = 'Erro ao carregar notícias.';
    }
  }

  // Executa a função ao carregar a página
  carregarNoticias();
</script>
